{
  "name": "affitor-sdk",
  "version": "0.3.0",
  "description": "Affitor tracking SDK — browser (init/signup), React wrapper (AffitorProvider/useAffitor), and Node server client (Affitor).",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": ["./dist/index.js"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "affiliate",
    "tracking",
    "affitor",
    "attribution",
    "sdk",
    "react"
  ],
  "author": "Affitor <hello@affitor.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Affitor/affiliate-cli",
    "directory": "packages/sdk"
  },
  "homepage": "https://affitor.com",
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "react": ">=17.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.1.0",
    "jsdom": "^25.0.0",
    "@types/node": "^22.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1"
  }
}
