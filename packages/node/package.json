{
  "name": "affitor-node",
  "version": "0.1.0",
  "description": "Affitor server-side SDK — typed trackLead()/trackSale() over the Affitor conversion API (Bearer). Provider-agnostic.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "affiliate",
    "tracking",
    "affitor",
    "attribution",
    "conversion",
    "server",
    "node"
  ],
  "author": "Affitor <hello@affitor.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Affitor/affiliate-cli",
    "directory": "packages/node"
  },
  "homepage": "https://affitor.com",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.1.0",
    "@types/node": "^22.0.0"
  }
}
